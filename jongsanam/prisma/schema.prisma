generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  image           String?  
  promptpayQR     String?  
  role            String    @default("USER")
  isBanned        Boolean   @default(false)
  
  posts           Post[]
  bookings        Booking[]
  comments        Comment[]
  
  reviewsGiven    Review[]  @relation("ReviewsGiven")
  reviewsReceived Review[]  @relation("ReviewsReceived")
  notifications   Notification[]
}

enum SportType {
  FOOTBALL
  FUTSAL
}

model Post {
  id             String    @id @default(cuid())
  title          String?
  sportType      SportType
  fieldName      String    
  startTime      DateTime  
  duration       Int       
  totalPrice     Decimal   @db.Decimal(10, 2) 
  maxPlayers     Int       
  description    String?
  passcode       String?
  status         String    @default("OPEN") 
  
  hostId         String
  host           Profile   @relation(fields: [hostId], references: [id])
  
  bookings       Booking[]
  comments       Comment[]
  reviews        Review[]
  createdAt      DateTime  @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  status    String   @default("JOINED") 
  
  post      Post     @relation(fields: [postId], references: [id])
  user      Profile  @relation(fields: [userId], references: [id])
  joinedAt  DateTime @default(now())

  @@unique([postId, userId]) 
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  rating     Int      
  comment    String?  
  createdAt  DateTime @default(now())

  reviewerId String
  reviewer   Profile  @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  revieweeId String
  reviewee   Profile  @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  postId     String?
  post       Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  
  @@unique([reviewerId, revieweeId, postId]) 
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   
  type      String   
  message   String
  read      Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())

  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
}